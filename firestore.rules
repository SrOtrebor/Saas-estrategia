rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (request.auth.token.admin == true || request.auth.token.email == 'Laforcada@gmail.com');
    }

    // Solo administradores pueden leer/escribir en el Dashboard (marcas y paquetes)
    match /marcas/{marcaId} {
      allow read, write: if isAdmin();
    }

    match /paquetes_plantillas/{paqueteId} {
      allow read, write: if isAdmin();
    }

    // Las colas internas son escritas por Cloud Functions (Admin SDK) — bloquear acceso web
    match /cola_ingesta/{docId} {
      allow read, write: if false;
    }

    match /cola_menu_semanal/{docId} {
      allow read, write: if false;
    }

    match /cola_generacion_menu/{docId} {
      allow read, write: if false;
    }

    match /cola_docs/{docId} {
      allow read, write: if false;
    }

    match /cola_test_plantillas/{docId} {
      allow read, write: if false;
    }

    // El planificador solo puede ser leído por administradores
    match /planificador_contenido/{postId} {
      allow read, write: if isAdmin();
    }

    // El banco de ideas solo puede ser leído por administradores
    match /banco_ideas/{ideaId} {
      allow read, write: if isAdmin();
    }

    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
