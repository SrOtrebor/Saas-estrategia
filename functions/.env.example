# ==============================================================
# VARIABLES DE ENTORNO — SaaS Estrategias (Firebase Functions)
# Copiar este archivo como .env y completar los valores reales.
# NUNCA commitear el archivo .env a Git.
# ==============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-...

# --- Bannerbear ---
BANNERBEAR_API_KEY=bb_...

# --- Telegram Bot (para notificaciones y webhooks de ingesta) ---
TELEGRAM_BOT_TOKEN=...
# El Secret Token que Telegram incluirá en el header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=...

# --- Meta / Instagram Graph API ---
META_APP_ID=...
META_APP_SECRET=...
# El Access Token de larga duración (Long-lived User Token o System User Token)
META_LONG_LIVED_TOKEN=...

# --- Firebase (solo para emulador local, en producción se infieren automáticamente) ---
FIREBASE_PROJECT_ID=saas-estrategias
