rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && (request.auth.token.admin == true || request.auth.token.email == 'Laforcada@gmail.com');
    }

    // Las imágenes generadas (posts) son de lectura pública (se envían por Telegram y a Instagram)
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Solo Cloud Functions (Admin SDK) puede escribir
    }

    // Los logos de los clientes son de lectura pública (se usan en las plantillas)
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin(); // Solo administradores pueden subir logos
    }

    // Bloquear cualquier otro path
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
